import BaseLayout from "../../layouts/BaseLayout.astro";
import PageShell from "../../reactPages/PageShell.astro";

const seo = pageSeo.about;
---

<BaseLayout title={seo.title} description={seo.description} path={seo.path}>
  <PageShell pathname={seo.path} page="about" aboutSection="overview" />
</BaseLayout>